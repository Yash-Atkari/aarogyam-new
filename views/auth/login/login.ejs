        padding: 0;
    }

    body {
        user-select: none;
        display: flex;
        justify-content: center;
        align-items: center;
        background: #0d948942;
        height: 100vh;
    }

    /* Login Container */
    .login-container {
        background: hsl(213, 85%, 97%);
        padding: 2em;
        border-radius: 30px;
        box-shadow: 0 0 2em hsl(231, 62%, 94%);
        width: 100%;
        max-width: 400px;
    }

    /* Input Fields */
    .input-box {
        margin-bottom: 1.5em;
    }

    .input-container {
        display: flex;
        align-items: center;
        gap: 0.5em;
        background: #fff;
        padding: 1em;
        border-radius: 20px;
        box-shadow: 0 0 2em hsl(231, 62%, 94%);
    }

    .input-container ion-icon {
        color: hsl(0, 0%, 30%);
    }

    .input-container input {
        flex: 1;
        border: none;
        outline: none;
        background: transparent;
    }

    /* Show/Hide Password Icon */
    .show-hide {
        cursor: pointer;
    }

    /* Login Button */
    .login-btn {
        padding: 1em;
        background: #0d9488;
        color: #fff;
        border: none;
        border-radius: 30px;
        font-weight: 600;
        cursor: pointer;
        width: 100%;
        transition: 0.3s ease;
    }

    .login-btn:hover {
       background-color: #0b8079;
      transform: translateY(-3px);
      box-shadow: 0 5px 15px rgba(13, 148, 136, 0.3);
    }
</style>
